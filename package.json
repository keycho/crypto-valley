{
  "name": "crypto-valley",
  "version": "0.0.0",
  "private": true,
  "description": "A cozy MMO where players excavate the ruins of a lost blockchain civilization.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint .",
    "validate": "pnpm --filter @crypto-valley/content validate",
    "db:generate": "pnpm --filter @crypto-valley/db db:generate",
    "db:migrate": "pnpm --filter @crypto-valley/db db:migrate",
    "db:seed": "pnpm --filter @crypto-valley/db db:seed"
  },
  "devDependencies": {
    "@crypto-valley/config": "workspace:*",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.17.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@swc/core", "sharp"]
  }
}
